# Copier ce fichier en ".env" et renseigner les valeurs ci-dessous.
# ".env" est ignoré par git (voir .gitignore) : n'y mettez jamais ce fichier en clair dans un commit.

# --- Obligatoire ---
# Token du bot Discord (Discord Developer Portal > Applications > votre bot > Bot > Token)
DDC_TOKEN=

# Nom du projet docker compose (garder identique entre le host et le service updater)
COMPOSE_PROJECT_NAME=ddcbot

# Chemin ABSOLU vers le dossier où ce dépôt est cloné sur la machine hôte.
# Obligatoire pour le service "updater" (auto-update) : docker doit pouvoir monter
# ce chemin depuis le démon hôte via le socket docker.sock.
# Exemple: /home/monuser/ddcbot
PROJECT_DIR=

# --- Optionnel ---
# ID du salon Discord où poster automatiquement le changelog après une mise à jour
CHANGELOG_CHANNEL_ID=

# ID du salon Discord où poster les erreurs de commande (journalisation des erreurs)
ERROR_LOG_CHANNEL_ID=

# Branche git surveillée par le service d'auto-update
GIT_BRANCH=master

# Intervalle (secondes) entre deux vérifications de mise à jour
CHECK_INTERVAL=60
